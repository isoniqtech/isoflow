# =====================================================
# ISOFlow — variáveis de ambiente
# Copia para .env.local e preenche com os teus valores
# =====================================================

# Supabase ---------------------------------------------
# https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude AI (extração de faturas) ----------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Twilio WhatsApp (inbound de faturas via WhatsApp) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Resend (email transacional + inbound) ----------------
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# Remetente dos emails transacionais (dominio verificado no Resend)
RESEND_FROM="ISOFlow <notificacoes@isoniqtech.com>"

# Stripe (subscrições + créditos) ----------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Tink (Open Banking — Visa) ---------------------------
# https://console.tink.com → app credentials
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=
# Secret partilhado para validar webhooks Tink (configurado em console.tink.com)
TINK_WEBHOOK_SECRET=

# App --------------------------------------------------
# URL pública da app (sem trailing slash). Usada para
# redirect URIs OAuth (Tink) e links em emails.
NEXT_PUBLIC_APP_URL=
ADMIN_EMAIL=
# Chave AES-256 em hex (gerar com: openssl rand -hex 32)
ENCRYPTION_KEY=
# UUID do super-admin (lookup em auth.users)
SUPER_ADMIN_USER_ID=

# Inbound de faturas + AI -----------------------------
# Bucket Supabase Storage onde guardamos PDFs/imagens
# das faturas recebidas via Telegram / Email / upload.
INVOICE_FILES_BUCKET=
# Domínio para gerar endereços inbound de email
# (ex: "isoflow.pt" → faturas+<tenant>@isoflow.pt)
INBOUND_EMAIL_DOMAIN=

# Gmail (OAuth — alternativa a Resend) ----------------
# Cada tenant pode ligar a sua Gmail via OAuth. Estas
# chaves são da app OAuth Google partilhada.
# Cria em: https://console.cloud.google.com
# → APIs & Services → Credentials → OAuth 2.0 Client ID
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Google Drive (documentos de projeto, por tenant). Scope: drive.file.
# Redirect URI a registar no Google Cloud:
#   {NEXT_PUBLIC_APP_URL}/api/integracoes/google-drive/oauth/callback
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# n8n (ERP forwarder default) -------------------------
# Webhook genérico n8n para onde o ISOFlow envia
# faturas processadas. Tenants podem dar override
# em tenant_integrations.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
# Webhook n8n que devolve as categorias de gasto do TOConline (modo n8n).
# Pode tambem ser definido por tenant em tenant_integrations.config.expense_categories_url
N8N_EXPENSE_CATEGORIES_URL=

# Vercel Cron Jobs ------------------------------------
# Secret partilhado para validar pedidos do Vercel Cron
# (header Authorization: Bearer <CRON_SECRET>). Usado
# para sync periódico do Tink, polling AT, etc.
CRON_SECRET=
